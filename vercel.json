{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "dist/BillsManager.UI/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/(..*\\.(?:js|css|json|ico|png|jpg|jpeg|svg|webp|woff|woff2|ttf|eot))",
      "dest": "/dist/BillsManager.UI/browser/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ]
}
