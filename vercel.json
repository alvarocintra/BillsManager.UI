{
  "version": 2,
  "cleanUrls": true,
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/dist/BillsManager.UI/browser/assets/$1"
    },
    {
      "src": "/(..*\\.(?:js|css|json|ico|png|jpg|jpeg|svg|webp|woff|woff2|ttf|eot))",
      "dest": "/dist/BillsManager.UI/browser/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
